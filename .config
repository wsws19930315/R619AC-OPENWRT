#=============================================================
# OpenWRT .config for P&W R619AC 128M
# 目标版本: OpenWRT 24.10.7 (官方源码)
#
# 功能清单:
#   - Passwall 科学上网
#   - Samba4 网络共享
#   - MWAN3 多线负载
#   - SmartDNS DNS 加速
#   - SQM QoS 流量控制
#   - Transmission BT 下载
#   - miniDLNA 媒体服务器
#   - Lucky 端口转发 / 反向代理
#   - Argon 主题 + 配置面板
#   - USB 存储 / IPv6 / PPPoE
#   - 系统监控 / 定时重启 / irqbalance
#=============================================================

#----- 目标平台 -----
CONFIG_TARGET_ipq40xx=y
CONFIG_TARGET_ipq40xx_generic=y
CONFIG_TARGET_ipq40xx_generic_DEVICE_p2w_r619ac-128m=y

#----- 编译优化 -----
CONFIG_DEVEL=y
CONFIG_CCACHE=y

#======================================
# LuCI 基础框架
#======================================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-lib-ipkg=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-mod-network=y
CONFIG_PACKAGE_luci-mod-status=y
CONFIG_PACKAGE_luci-mod-system=y
CONFIG_LUCI_LANG_zh_Hans=y

#----- 中文语言包 -----
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_luci-i18n-opkg-zh-cn=y

#----- 主题 -----
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-i18n-argon-config-zh-cn=y

#======================================
# 科学上网: Passwall
#======================================
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-i18n-passwall-zh-cn=y
CONFIG_PACKAGE_luci-i18n-passwall-zh-cn-release=y
CONFIG_PACKAGE_chinadns-ng=y
CONFIG_PACKAGE_dns2socks=y
CONFIG_PACKAGE_ipt2socks=y
CONFIG_PACKAGE_microsocks=y
CONFIG_PACKAGE_tcping=y
CONFIG_PACKAGE_xray-core=y
CONFIG_PACKAGE_v2ray-geoip=y
CONFIG_PACKAGE_v2ray-geosite=y
# CONFIG_PACKAGE_sing-box is not set

#======================================
# nftables 内核模块（fw4 + 科学上网必须）
#======================================
CONFIG_PACKAGE_kmod-nft-core=y
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_kmod-nft-socket=y
CONFIG_PACKAGE_kmod-nft-queue=y
CONFIG_PACKAGE_kmod-nf-conntrack=y
CONFIG_PACKAGE_kmod-nf-nat=y

#======================================
# 以太网 / DSA 交换机驱动（ipq40xx 必须）
#======================================
CONFIG_PACKAGE_kmod-essedma=y
CONFIG_PACKAGE_kmod-qca-nss-dp=y

#======================================
# DNS 增强
#======================================
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_dnsmasq_full_nftset=y
# CONFIG_PACKAGE_dnsmasq is not set

#======================================
# 防火墙
#======================================
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_nftables=y

#======================================
# Samba4 网络共享
#======================================
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_luci-i18n-samba4-zh-cn=y
CONFIG_PACKAGE_samba4-server=y
CONFIG_PACKAGE_samba4-libs=y
CONFIG_PACKAGE_samba4-utils=y
CONFIG_PACKAGE_wsdd2=y

#======================================
# MWAN3 多线负载均衡
#======================================
CONFIG_PACKAGE_luci-app-mwan3=y
CONFIG_PACKAGE_luci-i18n-mwan3-zh-cn=y
CONFIG_PACKAGE_mwan3=y

#======================================
# Frpc / Frps 内网穿透
#======================================
# CONFIG_PACKAGE_luci-app-frpc is not set
CONFIG_PACKAGE_luci-i18n-frpc-zh-cn=y
# CONFIG_PACKAGE_frpc is not set
# CONFIG_PACKAGE_luci-app-frps is not set
CONFIG_PACKAGE_luci-i18n-frps-zh-cn=y
# CONFIG_PACKAGE_frps is not set

#======================================
# SmartDNS DNS 加速
#======================================
CONFIG_PACKAGE_luci-app-smartdns=y
CONFIG_PACKAGE_luci-i18n-smartdns-zh-cn=y
CONFIG_PACKAGE_smartdns=y

#======================================
# SQM QoS 流量控制
#======================================
CONFIG_PACKAGE_luci-app-sqm=y
CONFIG_PACKAGE_luci-i18n-sqm-zh-cn=y
CONFIG_PACKAGE_sqm-scripts=y

#======================================
# KMS 服务器 (vlmcsd)
#======================================
# CONFIG_PACKAGE_luci-app-vlmcsd is not set
# CONFIG_PACKAGE_vlmcsd is not set

#======================================
# Transmission BT 下载
#======================================
CONFIG_PACKAGE_luci-app-transmission=y
CONFIG_PACKAGE_luci-i18n-transmission-zh-cn=y
CONFIG_PACKAGE_transmission-daemon=y
CONFIG_PACKAGE_transmission-cli=y
CONFIG_PACKAGE_transmission-web=y

#======================================
# miniDLNA 媒体服务器
#======================================
CONFIG_PACKAGE_minidlna=y
CONFIG_PACKAGE_luci-app-minidlna=y
CONFIG_PACKAGE_luci-i18n-minidlna-zh-cn=y

#======================================
# Lucky 端口转发 / 反向代理
#======================================
CONFIG_PACKAGE_lucky=y
CONFIG_PACKAGE_luci-app-lucky=y
CONFIG_PACKAGE_luci-i18n-lucky-zh-cn=y


#======================================
# 网速测试
#======================================
# CONFIG_PACKAGE_luci-app-netspeedtest is not set

#======================================
# 文件管理器 (无源，已取消)
#======================================
# CONFIG_PACKAGE_luci-app-filemanager is not set

#======================================
# 定时重启 / Watchcat
#======================================
CONFIG_PACKAGE_luci-app-watchcat=y
CONFIG_PACKAGE_luci-i18n-watchcat-zh-cn=y
CONFIG_PACKAGE_watchcat=y

#======================================
# irqbalance 多核中断均衡
#======================================
CONFIG_PACKAGE_irqbalance=y

#======================================
# DDNS 动态域名
#======================================
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_luci-i18n-ddns-zh-cn=y
CONFIG_PACKAGE_ddns-scripts=y
CONFIG_PACKAGE_ddns-scripts-cloudflare=y
CONFIG_PACKAGE_ddns-scripts-dnspod=y

#======================================
# UPnP 端口自动映射
#======================================
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-i18n-upnp-zh-cn=y

#======================================
# WiFi
#======================================
CONFIG_PACKAGE_wpad-openssl=y
# CONFIG_PACKAGE_wpad-basic-mbedtls is not set
# CONFIG_PACKAGE_wpad-basic is not set

#======================================
# USB 存储支持 (仅限 USB 2.0)
#======================================
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb-ehci=y
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-extras=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
CONFIG_PACKAGE_block-mount=y

CONFIG_PACKAGE_luci-app-hd-idle=y
CONFIG_PACKAGE_luci-i18n-hd-idle-zh-cn=y
CONFIG_PACKAGE_smartmontools=y

#----- 磁盘管理 -----

#----- 文件系统 -----
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-ntfs3=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_kmod-fuse=y
CONFIG_PACKAGE_kmod-nls-utf8=y
CONFIG_PACKAGE_ntfs3-mount=y
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_mount-utils=y


# 修复第三方包编译错误
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Geoview is not set
# CONFIG_PACKAGE_geoview is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_V2ray_Plugin is not set
# CONFIG_PACKAGE_v2ray-plugin is not set

#======================================
# IPv6 支持
#======================================
CONFIG_PACKAGE_ipv6helper=y
CONFIG_PACKAGE_ip6tables-nft=y
CONFIG_PACKAGE_odhcp6c=y
CONFIG_PACKAGE_odhcpd-ipv6only=y

#======================================
# PPPoE 支持（备用：光猫桥接时需要）
#======================================
CONFIG_PACKAGE_ppp=y
CONFIG_PACKAGE_ppp-mod-pppoe=y
CONFIG_PACKAGE_luci-proto-ppp=y

#======================================
# 系统监控
#======================================
CONFIG_PACKAGE_luci-app-statistics=y
CONFIG_PACKAGE_luci-i18n-statistics-zh-cn=y
CONFIG_PACKAGE_collectd=y
CONFIG_PACKAGE_collectd-mod-cpu=y
CONFIG_PACKAGE_collectd-mod-memory=y
CONFIG_PACKAGE_collectd-mod-interface=y
CONFIG_PACKAGE_collectd-mod-load=y
CONFIG_PACKAGE_collectd-mod-network=y
CONFIG_PACKAGE_collectd-mod-rrdtool=y

#======================================
# 系统工具
#======================================
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_lsblk=y
CONFIG_PACKAGE_parted=y
CONFIG_PACKAGE_blkid=y
CONFIG_PACKAGE_coreutils=y

CONFIG_PACKAGE_coreutils-nohup=y
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_openssh-sftp-server=y

#----- 补全缺失的中文包 -----
CONFIG_PACKAGE_luci-i18n-package-manager-zh-cn=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y
CONFIG_PACKAGE_luci-app-ttyd=y
